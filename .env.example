## Colossal HR Web — server-side env. Copy to .env.local and fill in.

# Frappe site this app talks to.
FRAPPE_URL=http://localhost:8000

# Server-to-server auth. Generate in Frappe:
#   bench --site recruitment.colossal execute frappe.core.doctype.user.user.generate_keys --args "['Administrator']"
# then copy the api_key + api_secret printed to terminal.
FRAPPE_API_KEY=
FRAPPE_API_SECRET=

# Optional override for the public site name shown in the topbar.
NEXT_PUBLIC_BRAND_NAME=Colossal HR

# Public Frappe URL — used on the client to resolve /files/... paths to
# absolute URLs (e.g. the profile-image preview after upload).
NEXT_PUBLIC_FRAPPE_URL=http://localhost:8000
